{
  "name": "social-politician",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n pb,vite \"npm run dev:pb\" \"npm run dev:vite\"",
    "dev:vite": "vite",
    "dev:live": "VITE_USE_LIVE_PB=true vite",
    "dev:pb": "./pb_linux/pocketbase serve --http=127.0.0.1:8091 --dir=./pocketbase/pb_data --migrationsDir=./pocketbase/pb_migrations",
    "build": "rm -rf web/dist && tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "preflight": "npm run typecheck && npm run build && npm run verify-build",
    "verify-build": "bash -c 'if grep -rE \"localhost:[0-9]|127\\\\.0\\\\.0\\\\.1:[0-9]\" web/dist 2>/dev/null; then echo \"ERROR: Found localhost/127.0.0.1 URL in build output!\" && exit 1; else echo \"✓ OK: No localhost URLs in build\"; fi'",
    "pb:patch-schema": "node scripts/pb_schema_patch_politicians.mjs",
    "pb:backfill": "node scripts/pb_backfill_politicians.mjs",
    "pb:backfill:live": "DRY_RUN=false node scripts/pb_backfill_politicians.mjs",
    "pb:fetch-wiki": "node scripts/fetch_wikipedia_urls.mjs",
    "pb:fetch-wiki:live": "DRY_RUN=false node scripts/fetch_wikipedia_urls.mjs",
    "pb:fetch-website": "node scripts/fetch_website_urls.mjs",
    "pb:fetch-website:live": "DRY_RUN=false node scripts/fetch_website_urls.mjs",
    "pb:import": "npx tsx server/src/scripts/importPoliticiansFromJSON.ts",
    "pb:import:executive": "npx tsx server/src/scripts/importPoliticiansFromJSON.ts --file=executive_import_ready.json",
    "pb:import:representatives": "npx tsx server/src/scripts/importPoliticiansFromJSON.ts --file=representatives_import_ready.json",
    "pb:reps:json": "npx tsx server/src/scripts/importRepresentativesFromWikipedia.ts --output-json",
    "pb:reps:import": "npx tsx server/src/scripts/importRepresentativesFromWikipedia.ts",
    "pb:backfill:reps-position-date": "npx tsx server/src/scripts/backfillRepresentativesPositionStartDate.ts",
    "pb:backfill:reps-position-date:dry": "npx tsx server/src/scripts/backfillRepresentativesPositionStartDate.ts --dry-run",
    "pb:backfill:governors-position-date": "npx tsx server/src/scripts/backfillGovernorsPositionStartDate.ts",
    "pb:backfill:governors-position-date:dry": "npx tsx server/src/scripts/backfillGovernorsPositionStartDate.ts --dry-run",
    "pb:backfill:governors-bios": "npx tsx server/src/scripts/backfillGovernorBios.ts",
    "pb:backfill:governors-bios:dry": "npx tsx server/src/scripts/backfillGovernorBios.ts --dry-run",
    "pb:backfill:reps-bios": "npx tsx server/src/scripts/backfillRepresentativesBios.ts",
    "pb:backfill:reps-bios:dry": "npx tsx server/src/scripts/backfillRepresentativesBios.ts --dry-run",
    "pb:admin:create": "./pb_linux/pocketbase superuser create admin@vma.agency 'VMAmadmia42O200!' --dir=./pocketbase/pb_data --migrationsDir=./pocketbase/pb_migrations",
    "pb:sync-from-live": "npx tsx server/src/scripts/syncFromLiveToLocal.ts",
    "pb:sync-to-live": "npx tsx server/src/scripts/syncFromLocalToLive.ts",
    "pb:delete-historical-presidents": "npx tsx server/src/scripts/deleteHistoricalPresidents.ts",
    "scrape:executive": "node scripts/scrape_portraits.js --office-type=executive",
    "scrape:five-missing-photos": "node scripts/scrape_portraits.js --slugs=donald-trump,howard-lutnick,robert-f-kennedy-jr,scott-bessent,sean-duffy --force && node scripts/upload_portraits.js --slugs=donald-trump,howard-lutnick,robert-f-kennedy-jr,scott-bessent,sean-duffy",
    "pb:backfill-bios:executive": "npx tsx server/src/scripts/backfillBiosFromWikipedia.ts --office-type=executive",
    "pb:backfill-executive-social": "npx tsx server/src/scripts/backfillExecutiveSocial.ts",
    "pb:enrich:executive": "npx tsx server/src/scripts/enrichPoliticiansFromWikipedia.ts --office-type=executive",
    "pb:enrich:social": "npx tsx server/src/scripts/enrichPoliticiansFromWikipedia.ts --fresh",
    "pb:enrich:social:executive": "npx tsx server/src/scripts/enrichPoliticiansFromWikipedia.ts --office-type=executive --fresh",
    "pb:enrich:social:google": "npx tsx server/src/scripts/enrichSocialFromGoogle.ts",
    "pb:enrich:social:google:executive": "npx tsx server/src/scripts/enrichSocialFromGoogle.ts --office-type=executive",
    "pb:enrich:social:google:governors": "npx tsx server/src/scripts/enrichSocialFromGoogle.ts --office-type=governor"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "form-data": "^4.0.5",
    "node-fetch": "^2.7.0",
    "openai": "^4.104.0",
    "pocketbase": "^0.22.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.1.0",
    "playwright": "^1.58.0",
    "sharp": "^0.34.5",
    "typescript": "^5.2.0",
    "vite": "^5.0.0"
  }
}
