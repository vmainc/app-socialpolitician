# PocketBase (local dev or scripts)
POCKETBASE_URL=http://127.0.0.1:8091
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=

# Optional: sync from live site
# LIVE_PB_URL=https://app.socialpolitician.com/pb

# Optional: enrich social links from Google Knowledge Panel (SerpApi)
# SERPAPI_API_KEY=

# Optional: AI summary for governor bios (2-paragraph backfill)
# OPENAI_API_KEY=

# Optional: Facebook Page Plugin embed on politician profiles (create app at developers.facebook.com)
# Set in build env when running Vite, e.g. VITE_FACEBOOK_APP_ID=123456789
# VITE_FACEBOOK_APP_ID=
